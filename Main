import tkinter as tk
from tkinter import messagebox
import sympy as sp

# --- CONFIGURACIÓN DE COLORES MODERNOS Y LIMPIOS ---
BG_COLOR = "#1E1E2E"        
PANEL_BG = "#282A36"        
FG_TEXT = "#F8F8F2"         
FG_ACCENT = "#8BE9FD"       
FG_SUCCESS = "#50FA7B"      
FG_ERROR = "#FF5555"        
BG_NOMBRES = "#6272A4"      # Color distinto para las casillas de texto

FONT_TITLE = ("Segoe UI", 24, "bold")
FONT_SUBTITLE = ("Segoe UI", 16, "bold")
FONT_MAIN = ("Segoe UI", 14)
FONT_EQ = ("Segoe UI", 20, "bold") 

# Valores por defecto
NOMBRES_EJEMPLO = ["KOH", "H3PO4", "K3PO4", "H2O"]
MATRIZ_EJEMPLO = [
    [1,  0, -3,  0],  # K
    [1,  4, -4, -1],  # O
    [1,  3,  0, -2],  # H
    [0,  1, -1,  0]   # P
]

def calcular_espacio_nulo():
    # Limpiar resultados anteriores
    lbl_ecuacion.config(text="Calculando...", fg=FG_TEXT)
    lbl_detalles.config(text="")
    
    try:
        # 1. Leer los nombres de las moléculas
        nombres = [entrada.get().strip() for entrada in entradas_nombres]
        # Si el usuario deja un espacio en blanco, ponemos un texto genérico
        for i in range(4):
            if not nombres[i]:
                nombres[i] = f"Molécula_{i+1}"

        # 2. Leer valores de la matriz numérica
        valores = []
        for i in range(4):
            fila = []
            for j in range(4):
                valor = int(entradas_matriz[i][j].get())
                fila.append(valor)
            valores.append(fila)
        
        # 3. Crear matriz y calcular Kernel
        A = sp.Matrix(valores)
        espacio_nulo = A.nullspace()

        if not espacio_nulo:
            lbl_ecuacion.config(text="ERROR: Sistema sin solución / No hay reacción", fg=FG_ERROR)
            return

        vector_base = espacio_nulo[0]

        # 4. MCM y coeficientes enteros
        mcm = 1
        for valor in vector_base:
            mcm = sp.lcm(mcm, valor.q)

        coeficientes = vector_base * mcm
        
        # 5. Mostrar la ecuación final usando los nombres personalizados
        ecuacion = f"{coeficientes[0]} {nombres[0]}  +  {coeficientes[1]} {nombres[1]}   ➔   {coeficientes[2]} {nombres[2]}  +  {coeficientes[3]} {nombres[3]}"
        lbl_ecuacion.config(text=ecuacion, fg=FG_SUCCESS)
        
        detalles = (
            f"Vector base original (Fracciones): {list(vector_base)}\n"
            f"Mínimo Común Múltiplo (MCM): {mcm}\n"
            f"Coeficientes Finales: {list(coeficientes)}"
        )
        lbl_detalles.config(text=detalles, fg=FG_ACCENT)

    except ValueError:
        lbl_ecuacion.config(text="ERROR: Ingrese solo números enteros en la matriz.", fg=FG_ERROR)
    except Exception as e:
        lbl_ecuacion.config(text=f"ERROR INESPERADO: {e}", fg=FG_ERROR)

def cerrar_sistema(event=None):
    root.destroy()

# --- CONFIGURACIÓN DE LA VENTANA PRINCIPAL ---
root = tk.Tk()
root.title("Balanceo Químico - Panel Limpio")
root.attributes('-fullscreen', True)
root.configure(bg=BG_COLOR)
root.bind("<Escape>", cerrar_sistema)

# --- HEADER ---
header_frame = tk.Frame(root, bg=BG_COLOR)
header_frame.pack(fill=tk.X, pady=20)

lbl_titulo = tk.Label(header_frame, text="Análisis Estequiométrico por Espacio Nulo", font=FONT_TITLE, bg=BG_COLOR, fg=FG_TEXT)
lbl_titulo.pack()

btn_salir = tk.Button(header_frame, text="Salir (ESC)", font=("Segoe UI", 12, "bold"), bg="#FF5555", fg="white", 
                      relief="flat", padx=15, command=cerrar_sistema)
btn_salir.place(relx=0.95, rely=0.5, anchor="e")

# --- CONTENEDOR PRINCIPAL (2 Paneles) ---
main_frame = tk.Frame(root, bg=BG_COLOR)
main_frame.pack(expand=True, fill=tk.BOTH, padx=60, pady=20)

# PANEL IZQUIERDO: ENTRADAS
panel_izq = tk.Frame(main_frame, bg=PANEL_BG, bd=0, highlightbackground="#44475A", highlightthickness=2)
panel_izq.pack(side=tk.LEFT, expand=True, fill=tk.BOTH, padx=20, pady=20)

lbl_matriz = tk.Label(panel_izq, text="Matriz de Composición Atómica", font=FONT_SUBTITLE, bg=PANEL_BG, fg=FG_ACCENT)
lbl_matriz.pack(pady=(30, 10))

lbl_instrucciones = tk.Label(panel_izq, text="Ingrese las moléculas arriba y sus respectivos átomos debajo:", font=("Segoe UI", 11), bg=PANEL_BG, fg=FG_TEXT)
lbl_instrucciones.pack(pady=(0, 20))

frame_cuadricula = tk.Frame(panel_izq, bg=PANEL_BG)
frame_cuadricula.pack()

# --- FILA SUPERIOR: CASILLAS PARA LOS NOMBRES ---
entradas_nombres = []
for j in range(4):
    ent_nombre = tk.Entry(frame_cuadricula, width=8, font=("Segoe UI", 14, "bold"), justify="center", 
                          bg=BG_NOMBRES, fg="#F8F8F2", insertbackground="#F8F8F2", relief="flat")
    # Lo colocamos en la fila 0 y le damos margen inferior para separarlo de los números
    ent_nombre.grid(row=0, column=j, padx=8, pady=(0, 15)) 
    ent_nombre.insert(0, NOMBRES_EJEMPLO[j])
    entradas_nombres.append(ent_nombre)

# --- FILAS INFERIORES: LA MATRIZ NUMÉRICA ---
entradas_matriz = []
for i in range(4):
    fila_entradas = []
    for j in range(4):
        entrada = tk.Entry(frame_cuadricula, width=5, font=("Segoe UI", 20), justify="center", 
                           bg="#44475A", fg=FG_TEXT, insertbackground=FG_TEXT, relief="flat")
        # Las empezamos a ubicar desde la fila 1 en adelante
        entrada.grid(row=i+1, column=j, padx=8, pady=8)
        entrada.insert(0, str(MATRIZ_EJEMPLO[i][j]))
        fila_entradas.append(entrada)
    entradas_matriz.append(fila_entradas)

btn_calcular = tk.Button(panel_izq, text="Calcular Balanceo", font=FONT_SUBTITLE, bg="#50FA7B", fg="#282A36", 
                         relief="flat", padx=20, pady=10, command=calcular_espacio_nulo)
btn_calcular.pack(pady=40)

# PANEL DERECHO: RESULTADOS
panel_der = tk.Frame(main_frame, bg=PANEL_BG, bd=0, highlightbackground="#44475A", highlightthickness=2)
panel_der.pack(side=tk.RIGHT, expand=True, fill=tk.BOTH, padx=20, pady=20)

lbl_res_titulo = tk.Label(panel_der, text="Resultado del Balanceo", font=FONT_SUBTITLE, bg=PANEL_BG, fg=FG_ACCENT)
lbl_res_titulo.pack(pady=(30, 40))

# Etiqueta gigante para la ecuación
lbl_ecuacion = tk.Label(panel_der, text="Esperando datos...", font=FONT_EQ, bg=PANEL_BG, fg=FG_TEXT, wraplength=500)
lbl_ecuacion.pack(pady=30)

# Separador visual
tk.Frame(panel_der, bg="#44475A", height=2, width=400).pack(pady=20)

# Etiqueta para los detalles matemáticos (Kernel y MCM)
lbl_detalles = tk.Label(panel_der, text="", font=FONT_MAIN, bg=PANEL_BG, fg=FG_TEXT, justify="center")
lbl_detalles.pack(pady=20)

# Iniciar el bucle
root.mainloop()
